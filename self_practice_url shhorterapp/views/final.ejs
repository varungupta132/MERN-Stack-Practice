<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Show Data</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background: linear-gradient(135deg, #667eea, #764ba2);
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* Card */
.card-box{
    background: white;
    padding: 30px;
    border-radius: 15px;
    width: 350px;
    text-align: center;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

/* Title */
.card-box h2{
    margin-bottom: 20px;
}

/* Data styling */
.data{
    font-size: 18px;
    margin: 10px 0;
    padding: 10px;
    background: #f1f1f1;
    border-radius: 8px;
}

/* Button */
.btn-custom{
    margin-top: 15px;
}

</style>
</head>

<body>

<div class="card-box">

    <h2>User Details</h2>

    <!-- Data 1 -->
    <div class="data">
        Original URL : <%= url %>
    </div>

    <!-- Data 2 -->
    <div class="data">
       Generated URL:  <a href ="http://localhost:3000/<%= gene %>" > http://localhost:3000/<%= gene %> </a>
    </div>

    <!-- Buttons --> 
    <a href="/" class="btn btn-secondary btn-custom">Go Back</a>
    <!-- <a href="/short_kerde/<%= url %>" class="btn btn-primary btn-custom">generate shorter url</a> -->

</div>

</body>
</html>