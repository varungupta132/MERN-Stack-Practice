<!DOCTYPE html>
<html>
<head>
  <title>Users</title>
</head>
<body>

  <h1>Users List</h1>

  <% users.forEach(user => { %>
    <div style="border:1px solid #ccc; margin:10px; padding:10px;">
      <p><b>ID:</b> <%= user.id %></p>
      <p><b>Name:</b> <%= user.name %></p>
      <p><b>Age:</b> <%= user.age %></p>
      <p><b>City:</b> <%= user.city %></p>
    </div>
  <% }) %>

</body>
</html>
